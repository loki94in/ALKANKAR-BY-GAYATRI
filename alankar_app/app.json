{
  "expo": {
    "name": "Alankar by Gayatri",
    "slug": "alankar_app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0101"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo.png",
        "backgroundColor": "#0F0101"
      },
      "package": "com.gayatri.alankar"
    },
    "scheme": "alankar",
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6a67ccbb-c0cf-4704-8b4d-7870fbb04027"
      }
    }
  }
}
